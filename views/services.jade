extends layout

block content
  section(style="padding: 100px 20px; background-color: #0f0f1b; color: white; font-family: 'Segoe UI', sans-serif; text-align: center;")
    h2(style="font-size: 5vw; font-weight: 800; margin-bottom: 60px; text-transform: uppercase; letter-spacing: -2px;")
      | Our 
      span(style="color: #4ecca3;") Services
    
    div(style="display: flex; flex-wrap: wrap; justify-content: center; gap: 30px; max-width: 1200px; margin: 0 auto;")
      //- Service 1
      div(style="flex: 1; min-width: 300px; background: rgba(255,255,255,0.05); padding: 40px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 30px rgba(0,0,0,0.3);")
        h3(style="font-size: 1.8rem; color: #4ecca3; margin-bottom: 15px;") Cloud Hosting
        p(style="font-size: 1.1rem; line-height: 1.6; opacity: 0.8;") Scalable and highly available cloud infrastructure solutions tailored to your business needs.

      //- Service 2
      div(style="flex: 1; min-width: 300px; background: rgba(255,255,255,0.05); padding: 40px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 30px rgba(0,0,0,0.3);")
        h3(style="font-size: 1.8rem; color: #4ecca3; margin-bottom: 15px;") Custom Development
        p(style="font-size: 1.1rem; line-height: 1.6; opacity: 0.8;") End-to-end software development services from requirements analysis to deployment.

      //- Service 3
      div(style="flex: 1; min-width: 300px; background: rgba(255,255,255,0.05); padding: 40px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 30px rgba(0,0,0,0.3);")
        h3(style="font-size: 1.8rem; color: #4ecca3; margin-bottom: 15px;") IT Consulting
        p(style="font-size: 1.1rem; line-height: 1.6; opacity: 0.8;") Expert advice and strategy to optimize your system architectures and streamline workflows.
